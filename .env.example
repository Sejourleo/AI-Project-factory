# LLM topic-insights pipeline (POST /api/insights/generate)
# provider: 'openai' (any OpenAI-compatible /v1/chat/completions endpoint with response_format: json_schema)
#           'anthropic' (Anthropic /v1/messages with forced tool_use)
LLM_PROVIDER=openai
LLM_BASE_URL=https://api.openai.com
