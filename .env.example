WECHAT_SEARCH_API_KEY=your-api-key-here
WECHAT_SEARCH_API_URL=http://cn8n.com/p4/fbmain/monitor/v3/kw_search

# LLM topic-insights pipeline (POST /api/insights/generate)
# Any OpenAI-compatible /v1/chat/completions endpoint that supports response_format: json_schema.
# LLM_BASE_URL must be the host without /v1 — the client appends /v1/chat/completions itself.
LLM_PROVIDER=openai
LLM_BASE_URL=https://api.openai.com
LLM_API_KEY=sk-your-key-here
LLM_MODEL=gpt-4o-mini

# Studio Agent — content generation (POST /api/studio/generate)
# Any OpenAI-compatible chat completions endpoint. Used by the creation flow under /studio.
SILICONFLOW_API_KEY=sk-your-key-here
SILICONFLOW_BASE_URL=https://api.siliconflow.cn/v1
SILICONFLOW_MODEL=Pro/moonshotai/Kimi-K2-Instruct-0905

# Studio Agent — WeChat publish (POST /api/studio/wechat/{accounts,publish})
WECHAT_API_KEY=your-wechat-publish-api-key
WECHAT_API_BASE_URL=https://wx.limyai.com/api/openapi
